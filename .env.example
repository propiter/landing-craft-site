# The URL that /api/contact forwards form submissions to.
# Can be n8n webhook, Resend, Discord webhook, Zapier, etc.
# Your n8n webhook (or Resend, Discord, Zapier, etc.).
# Leave empty for test mode.
NEXT_PUBLIC_FORM_ENDPOINT=

# Canonical site URL for SEO (OG tags, JSON-LD, sitemap).
# Falls back to the default in src/lib/site-config.ts.
NEXT_PUBLIC_SITE_URL=https://landing-craft.vercel.app

# Google Analytics 4 measurement ID (optional).
# Only wired if present — reads NEXT_PUBLIC_GA_MEASUREMENT_ID.
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager container ID (optional).
# Only wired if present — reads NEXT_PUBLIC_GTM_ID.
# If both GA_MEASUREMENT_ID and GTM_ID are set, GA4 is used standalone.
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
